	Label.Size = UDim2.new(1, -50, 1, 0)
	Label.Position = UDim2.new(0, 10, 0, 0)
	Label.BackgroundTransparency = 1
	Label.TextColor3 = TEXT
	Label.Font = Enum.Font.GothamSemibold
	Label.TextSize = 12
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Frame

	local Track = Instance.new("TextButton")
	Track.Size = UDim2.new(0, 36, 0, 18)
	Track.Position = UDim2.new(1, -44, 0.5, -9)
	Track.BackgroundColor3 = state and PURPLE or OFF
	Track.Text = ""
	Track.BorderSizePixel = 0
	Track.Parent = Frame

	Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

	local Knob = Instance.new("Frame")
	Knob.Size = Instance.new("UICorner", Knob) and UDim2.new(0, 14, 0, 14)
	Knob.Position = state and UDim2.new(0, 20, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
	Knob.BackgroundColor3 = TEXT
	Knob.BorderSizePixel = 0
	Knob.Parent = Track

	Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)

	Track.MouseButton1Click:Connect(function()
		state = not state
		TweenService:Create(Track, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = state and PURPLE or OFF}):Play()
		TweenService:Create(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Position = state and UDim2.new(0, 20, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}):Play()
		if callback then pcall(callback, state) end
	end)

	return Frame
end

-- ===== CREATE DROPDOWN =====
function ProjectGalaxy:CreateDropdown(tab, text, options, default, callback)
	local selected = default or (options and options[1]) or "Select..."
	local isOpen = false

	local Wrapper = Instance.new("Frame")
	Wrapper.Size = UDim2.new(1, 0, 0, 48)
	Wrapper.BackgroundTransparency = 1
	Wrapper.Parent = tab.Content

	local Label = Instance.new("TextLabel")
	Label.Text = text
	Label.Size = UDim2.new(1, 0, 0, 16)
	Label.BackgroundTransparency = 1
	Label.TextColor3 = SUBTEXT
	Label.Font = Enum.Font.GothamSemibold
	Label.TextSize = 11
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Wrapper

	local DropBtn = Instance.new("TextButton")
	DropBtn.Size = UDim2.new(1, 0, 0, 26)
	DropBtn.Position = UDim2.new(0, 0, 0, 18)
	DropBtn.BackgroundColor3 = PURPLE_DARK
	DropBtn.BackgroundTransparency = 0.4
	DropBtn.Text = "  " .. selected .. "  ▾"
	DropBtn.TextColor3 = TEXT
	DropBtn.Font = Enum.Font.Gotham
	DropBtn.TextSize = 11
	DropBtn.TextXAlignment = Enum.TextXAlignment.Left
	DropBtn.BorderSizePixel = 0
	DropBtn.Parent = Wrapper

	Instance.new("UICorner", DropBtn).CornerRadius = UDim.new(0, 5)

	local List = Instance.new("ScrollingFrame")
	List.BackgroundColor3 = DROPDOWN_BG
	List.BorderSizePixel = 0
	List.Visible = false
	List.ZIndex = 100
	List.ScrollBarThickness = 2
	List.AutomaticCanvasSize = Enum.AutomaticSize.Y
	List.CanvasSize = UDim2.new(0,0,0,0)
	List.Parent = self.ScreenGui

	Instance.new("UICorner", List).CornerRadius = UDim.new(0, 5)
	Instance.new("UIStroke", List).Color = PURPLE

	local LLayout = Instance.new("UIListLayout")
	LLayout.SortOrder = Enum.SortOrder.LayoutOrder
	LLayout.Parent = List

	local ITEM_H = 24
	for _, opt in ipairs(options or {}) do
		local OptBtn = Instance.new("TextButton")
		OptBtn.Size = UDim2.new(1, 0, 0, ITEM_H)
		OptBtn.BackgroundColor3 = PURPLE
		OptBtn.BackgroundTransparency = 1
		OptBtn.Text = "  " .. opt
		OptBtn.TextColor3 = TEXT
		OptBtn.Font = Enum.Font.Gotham
		OptBtn.TextSize = 11
		OptBtn.TextXAlignment = Enum.TextXAlignment.Left
		OptBtn.ZIndex = 101
		OptBtn.BorderSizePixel = 0
		OptBtn.Parent = List

		OptBtn.MouseButton1Click:Connect(function()
			selected = opt
			DropBtn.Text = "  " .. opt .. "  ▾"
			List.Visible = false
			isOpen = false
			if callback then pcall(callback, opt) end
		end)
	end

	DropBtn.MouseButton1Click:Connect(function()
		isOpen = not isOpen
		if isOpen then
			local pos = DropBtn.AbsolutePosition
			local size = DropBtn.AbsoluteSize
			List.Size = UDim2.new(0, size.X, 0, math.min(#options * ITEM_H, 100))
			List.Position = UDim2.new(0, pos.X, 0, pos.Y + size.Y + 2)
		end
		List.Visible = isOpen
	end)

	return Wrapper
end

