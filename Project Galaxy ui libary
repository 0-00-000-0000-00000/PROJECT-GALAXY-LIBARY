	end)

	return bubble
end

-- ===== CREATE WINDOW =====
function ProjectGalaxy:CreateWindow(title)
	local Window = setmetatable({}, ProjectGalaxy)

	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "ProjectGalaxyLibrary"
	ScreenGui.ResetOnSpawn = false
	ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	
	-- Safe CoreGui parenting check
	local success, _ = pcall(function() ScreenGui.Parent = game:GetService("CoreGui") end)
	if not success then ScreenGui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui") end

	-- Main frame
	local Main = Instance.new("Frame")
	Main.Size = UDim2.new(0, WINDOW_WIDTH, 0, WINDOW_HEIGHT)
	Main.Position = UDim2.new(0.5, -WINDOW_WIDTH/2, 0.5, -WINDOW_HEIGHT/2)
	Main.BackgroundColor3 = BG
	Main.BackgroundTransparency = 0.05
	Main.BorderSizePixel = 0
	Main.ClipsDescendants = true
	Main.Parent = ScreenGui

	local MainCorner = Instance.new("UICorner", Main)
	MainCorner.CornerRadius = UDim.new(0, 10)

	local MainStroke = Instance.new("UIStroke", Main)
	MainStroke.Color = PURPLE
	MainStroke.Thickness = 1.5

	-- Title bar
	local TitleBar = Instance.new("Frame")
	TitleBar.Size = UDim2.new(1, 0, 0, 35)
	TitleBar.BackgroundColor3 = PURPLE_DARK
	TitleBar.BackgroundTransparency = 0.4
	TitleBar.BorderSizePixel = 0
	TitleBar.Parent = Main

	local TitleCorner = Instance.new("UICorner", TitleBar)
	TitleCorner.CornerRadius = UDim.new(0, 10)

	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.Text = title or "Project Galaxy"
	TitleLabel.Size = UDim2.new(1, -80, 1, 0)
	TitleLabel.Position = UDim2.new(0, 12, 0, 0)
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.TextColor3 = TEXT
	TitleLabel.Font = Enum.Font.GothamBold
	TitleLabel.TextSize = IsTouch and 13 or 15
	TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
	TitleLabel.Parent = TitleBar

	-- Close button
	local CloseBtn = Instance.new("TextButton")
	CloseBtn.Text = "×"
	CloseBtn.Size = UDim2.new(0, 25, 0, 25)
	CloseBtn.Position = UDim2.new(1, -30, 0.5, -12.5)
	CloseBtn.BackgroundTransparency = 1
	CloseBtn.TextColor3 = TEXT
	CloseBtn.Font = Enum.Font.GothamBold
	CloseBtn.TextSize = 20
	CloseBtn.ZIndex = 10
	CloseBtn.Parent = TitleBar

	CloseBtn.MouseButton1Click:Connect(function()
		TweenService:Create(Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, WINDOW_WIDTH, 0, 0), BackgroundTransparency = 1}):Play()
		task.wait(0.2)
		if Window._bubble then Window._bubble:Destroy() end
		ScreenGui:Destroy()
	end)

	-- Minimize button
	local MinBtn = Instance.new("TextButton")
	MinBtn.Text = "—"
	MinBtn.Size = UDim2.new(0, 25, 0, 25)
	MinBtn.Position = UDim2.new(1, -55, 0.5, -12.5)
	MinBtn.BackgroundTransparency = 1
	MinBtn.TextColor3 = TEXT
	MinBtn.Font = Enum.Font.GothamBold
	MinBtn.TextSize = 14
	MinBtn.ZIndex = 10
	MinBtn.Parent = TitleBar

	MinBtn.MouseButton1Click:Connect(function()
		Window:Minimize()
	end)

	-- Sidebar
	local Sidebar = Instance.new("Frame")
	Sidebar.Size = UDim2.new(0, 110, 1, -40)
	Sidebar.Position = UDim2.new(0, 5, 0, 40)
	Sidebar.BackgroundTransparency = 1
	Sidebar.Parent = Main

	local TabScroll = Instance.new("ScrollingFrame")
	TabScroll.Size = UDim2.new(1, 0, 1, 0)
	TabScroll.BackgroundTransparency = 1
	TabScroll.ScrollBarThickness = 0
	TabScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	TabScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	TabScroll.Parent = Sidebar

	local TabLayout = Instance.new("UIListLayout")
	TabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	TabLayout.Padding = UDim.new(0, 5)
	TabLayout.Parent = TabScroll

	-- Content area
	local ContentArea = Instance.new("Frame")
	ContentArea.Size = UDim2.new(1, -125, 1, -45)
	ContentArea.Position = UDim2.new(0, 120, 0, 40)
	ContentArea.BackgroundTransparency = 1
	ContentArea.ClipsDescendants = true
	ContentArea.Parent = Main

	MakeDraggable(TitleBar, Main)

	-- Animations & Window Functions
	function Window:Minimize()
		if not Window._bubble then
			Window._bubble = CreateBubble(ScreenGui, Window)
		end
		Window._savedPosition = Main.Position
		
		local tween = TweenService:Create(Main, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Size = UDim2.new(0, WINDOW_WIDTH, 0, 0),
			BackgroundTransparency = 1
		})
		tween:Play()
		tween.Completed:Connect(function()
			Main.Visible = false
			Window._bubble.Visible = true
		end)
	end

	function Window:Restore()
		Main.Visible = true
		if Window._savedPosition then
			Main.Position = Window._savedPosition
		end
		if Window._bubble then
			Window._bubble.Visible = false
		end
		TweenService:Create(Main, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, WINDOW_WIDTH, 0, WINDOW_HEIGHT),
			BackgroundTransparency = 0.05
		}):Play()
	end

	-- Intro Opening Animation
	Main.Size = UDim2.new(0, WINDOW_WIDTH, 0, 0)
	TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, WINDOW_WIDTH, 0, WINDOW_HEIGHT)}):Play()

	Window.ScreenGui = ScreenGui
	Window.TabScroll = TabScroll
	Window.ContentArea = ContentArea
	Window.Tabs = {}
	Window.CurrentTab = nil

	return Window
end

-- ===== CREATE TAB =====
function ProjectGalaxy:CreateTab(name)
	local Tab = {}

	local TabBtn = Instance.new("TextButton")
	TabBtn.Size = UDim2.new(1, -4, 0, 28)
	TabBtn.BackgroundColor3 = PURPLE
	TabBtn.BackgroundTransparency = 0.85
	TabBtn.Text = name
	TabBtn.TextColor3 = SUBTEXT
	TabBtn.Font = Enum.Font.GothamSemibold
	TabBtn.TextSize = 12
	TabBtn.BorderSizePixel = 0
	TabBtn.Parent = self.TabScroll

	Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 5)

	local TabContent = Instance.new("ScrollingFrame")
	TabContent.Size = UDim2.new(1, 0, 1, 0)
	TabContent.BackgroundTransparency = 1
	TabContent.ScrollBarThickness = 2
	TabContent.ScrollBarImageColor3 = PURPLE
	TabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
	TabContent.CanvasSize = UDim2.new(0, 0, 0, 0)
	TabContent.Visible = false
	TabContent.Parent = self.ContentArea

	local ContentLayout = Instance.new("UIListLayout")
	ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
	ContentLayout.Padding = UDim.new(0, 6)
	ContentLayout.Parent = TabContent

	local ContentPad = Instance.new("UIPadding")
	ContentPad.PaddingLeft = UDim.new(0, 4)
	ContentPad.PaddingRight = UDim.new(0, 8)
	ContentPad.PaddingTop = UDim.new(0, 4)
	ContentPad.PaddingBottom = UDim.new(0, 4)
	ContentPad.Parent = TabContent

	Tab.Button = TabBtn
	Tab.Content = TabContent

	TabBtn.MouseButton1Click:Connect(function()
		if self.CurrentTab and self.CurrentTab ~= Tab then
			self.CurrentTab.Content.Visible = false
			TweenService:Create(self.CurrentTab.Button, TweenInfo.new(0.15), { BackgroundTransparency = 0.85, TextColor3 = SUBTEXT }):Play()
		end
		if self.CurrentTab ~= Tab then
			TabContent.Visible = true
			TabContent.CanvasPosition = Vector2.new(0,0)
			TweenService:Create(TabBtn, TweenInfo.new(0.15), { BackgroundTransparency = 0.4, TextColor3 = TEXT }):Play()
			self.CurrentTab = Tab
		end
	end)

	if not self.CurrentTab then
		TabContent.Visible = true
		TabBtn.BackgroundTransparency = 0.4
		TabBtn.TextColor3 = TEXT
		self.CurrentTab = Tab
	end

	table.insert(self.Tabs, Tab)
	return Tab
end

