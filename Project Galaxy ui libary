		else
			CreateTween(ListWrapper, {Size = UDim2.new(1, 0, 0, 0)}, 0.25)
			CreateTween(ListStroke, {Transparency = 1}, 0.2)
			CreateTween(DropStroke, {Color = OUTLINE}, 0.2)
			CreateTween(Icon, {Rotation = 0}, 0.2)
			Icon.Text = "+"
			CreateTween(Frame, {Size = UDim2.new(1, 0, 0, 60)}, 0.25)
		end
	end)

	return Frame
end

function ProjectGalaxy:CreateKeybind(tab, text, defaultKey, callback)
	local currentKey = defaultKey or Enum.KeyCode.Unknown
