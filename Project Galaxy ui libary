local ProjectGalaxy = {}
ProjectGalaxy.__index = ProjectGalaxy

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local INDIGO = Color3.fromRGB(120, 80, 255)
local INDIGO_DARK = Color3.fromRGB(80, 50, 180)
local BG = Color3.fromRGB(20, 20, 30)
local TEXT = Color3.fromRGB(255, 255, 255)
local SUBTEXT = Color3.fromRGB(200, 200, 220)
local OFF = Color3.fromRGB(60, 60, 75)

function ProjectGalaxy:CreateWindow(title)
	local Window = setmetatable({}, ProjectGalaxy)

	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "ProjectGalaxyLibrary"
	ScreenGui.ResetOnSpawn = false
	ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	ScreenGui.Parent = game.CoreGui

	local Main = Instance.new("Frame")
	Main.Size = UDim2.new(0, 620, 0, 480)
	Main.Position = UDim2.new(0.5, -310, 0.5, -240)
	Main.BackgroundColor3 = BG
	Main.BackgroundTransparency = 0.1
	Main.BorderSizePixel = 0
	Main.Parent = ScreenGui

	Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)

	local MainStroke = Instance.new("UIStroke", Main)
	MainStroke.Color = INDIGO
	MainStroke.Thickness = 2
	MainStroke.Transparency = 0.1

	local TitleBar = Instance.new("Frame")
	TitleBar.Size = UDim2.new(1, 0, 0, 50)
	TitleBar.BackgroundColor3 = INDIGO_DARK
	TitleBar.BackgroundTransparency = 0.35
	TitleBar.BorderSizePixel = 0
	TitleBar.Parent = Main

	Instance.new("UICorner", TitleBar).CornerRadius = UDim.new(0, 12)

	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.Text = title or "Project Galaxy Library"
	TitleLabel.Size = UDim2.new(1, -60, 1, 0)
	TitleLabel.Position = UDim2.new(0, 18, 0, 0)
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.TextColor3 = TEXT
	TitleLabel.Font = Enum.Font.GothamBold
	TitleLabel.TextSize = 18
	TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
	TitleLabel.Parent = TitleBar

	local CloseBtn = Instance.new("TextButton")
	CloseBtn.Text = "×"
	CloseBtn.Size = UDim2.new(0, 38, 0, 38)
	CloseBtn.Position = UDim2.new(1, -44, 0, 6)
	CloseBtn.BackgroundTransparency = 1
	CloseBtn.TextColor3 = TEXT
	CloseBtn.Font = Enum.Font.GothamBold
	CloseBtn.TextSize = 26
	CloseBtn.Parent = TitleBar
	CloseBtn.MouseButton1Click:Connect(function()
		ScreenGui:Destroy()
	end)

	local Sidebar = Instance.new("Frame")
	Sidebar.Size = UDim2.new(0, 145, 1, -55)
	Sidebar.Position = UDim2.new(0, 5, 0, 55)
	Sidebar.BackgroundTransparency = 1
	Sidebar.Parent = Main

	local TabScroll = Instance.new("ScrollingFrame")
	TabScroll.Size = UDim2.new(1, 0, 1, 0)
	TabScroll.BackgroundTransparency = 1
	TabScroll.ScrollBarThickness = 3
	TabScroll.ScrollBarImageColor3 = INDIGO
	TabScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	TabScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	TabScroll.Parent = Sidebar

	local TabLayout = Instance.new("UIListLayout")
	TabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	TabLayout.Padding = UDim.new(0, 6)
	TabLayout.Parent = TabScroll

	local TabPad = Instance.new("UIPadding")
	TabPad.PaddingTop = UDim.new(0, 8)
	TabPad.PaddingLeft = UDim.new(0, 6)
	TabPad.PaddingRight = UDim.new(0, 6)
	TabPad.Parent = TabScroll

	local ContentArea = Instance.new("Frame")
	ContentArea.Size = UDim2.new(1, -158, 1, -60)
	ContentArea.Position = UDim2.new(0, 155, 0, 58)
	ContentArea.BackgroundTransparency = 1
	ContentArea.ClipsDescendants = true
	ContentArea.Parent = Main

	local dragging, dragStart, startPos = false, nil, nil

	TitleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = Main.Position
		end
	end)

	TitleBar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			Main.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)

	Window.ScreenGui = ScreenGui
	Window.Main = Main
	Window.TabScroll = TabScroll
	Window.ContentArea = ContentArea
	Window.Tabs = {}
	Window.CurrentTab = nil

	return Window
end

function ProjectGalaxy:CreateTab(name)
	local Tab = {}

	local TabBtn = Instance.new("TextButton")
	TabBtn.Size = UDim2.new(1, 0, 0, 38)
	TabBtn.BackgroundColor3 = INDIGO
	TabBtn.BackgroundTransparency = 0.75
	TabBtn.Text = name
	TabBtn.TextColor3 = TEXT
	TabBtn.Font = Enum.Font.GothamSemibold
	TabBtn.TextSize = 14
	TabBtn.BorderSizePixel = 0
	TabBtn.Parent = self.TabScroll

	Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 8)

	local TBStroke = Instance.new("UIStroke", TabBtn)
	TBStroke.Color = INDIGO
	TBStroke.Thickness = 1.5

	local TabContent = Instance.new("ScrollingFrame")
	TabContent.Size = UDim2.new(1, 0, 1, 0)
	TabContent.BackgroundTransparency = 1
	TabContent.ScrollBarThickness = 4
	TabContent.ScrollBarImageColor3 = INDIGO
	TabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
	TabContent.CanvasSize = UDim2.new(0, 0, 0, 0)
	TabContent.Visible = false
	TabContent.Parent = self.ContentArea

	local ContentLayout = Instance.new("UIListLayout")
	ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
	ContentLayout.Padding = UDim.new(0, 10)
	ContentLayout.Parent = TabContent

	local ContentPad = Instance.new("UIPadding")
	ContentPad.PaddingLeft = UDim.new(0, 8)
	ContentPad.PaddingRight = UDim.new(0, 8)
	ContentPad.PaddingTop = UDim.new(0, 8)
	ContentPad.PaddingBottom = UDim.new(0, 8)
	ContentPad.Parent = TabContent

	Tab.Button = TabBtn
	Tab.Content = TabContent

	TabBtn.MouseButton1Click:Connect(function()
		if self.CurrentTab and self.CurrentTab ~= Tab then
			self.CurrentTab.Content.Visible = false
			TweenService:Create(self.CurrentTab.Button, TweenInfo.new(0.18), { BackgroundTransparency = 0.75 }):Play()
		end
		if self.CurrentTab ~= Tab then
			TabContent.Visible = true
			TweenService:Create(TabBtn, TweenInfo.new(0.18), { BackgroundTransparency = 0.3 }):Play()
			self.CurrentTab = Tab
		end
	end)

	if not self.CurrentTab then
		TabContent.Visible = true
		TabBtn.BackgroundTransparency = 0.3
		self.CurrentTab = Tab
	end

	table.insert(self.Tabs, Tab)
	return Tab
end

function ProjectGalaxy:CreateSection(tab, title)
	local Section = Instance.new("Frame")
	Section.Size = UDim2.new(1, 0, 0, 32)
	Section.BackgroundTransparency = 1
	Section.Parent = tab.Content

	local Label = Instance.new("TextLabel")
	Label.Text = title
	Label.Size = UDim2.new(1, 0, 0, 22)
	Label.BackgroundTransparency = 1
	Label.TextColor3 = INDIGO
	Label.Font = Enum.Font.GothamBold
	Label.TextSize = 15
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Section

	local Divider = Instance.new("Frame")
	Divider.Size = UDim2.new(1, 0, 0, 1)
	Divider.Position = UDim2.new(0, 0, 0, 26)
	Divider.BackgroundColor3 = INDIGO
	Divider.BackgroundTransparency = 0.55
	Divider.BorderSizePixel = 0
	Divider.Parent = Section

	return Section
end

function ProjectGalaxy:CreateButton(tab, text, callback)
	local Btn = Instance.new("TextButton")
	Btn.Size = UDim2.new(1, 0, 0, 40)
	Btn.BackgroundColor3 = INDIGO
	Btn.BackgroundTransparency = 0.55
	Btn.Text = text
	Btn.TextColor3 = TEXT
	Btn.Font = Enum.Font.GothamSemibold
	Btn.TextSize = 14
	Btn.BorderSizePixel = 0
	Btn.Parent = tab.Content

	Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)

	local BStroke = Instance.new("UIStroke", Btn)
	BStroke.Color = INDIGO
	BStroke.Thickness = 1.5

	Btn.MouseButton1Click:Connect(function()
		TweenService:Create(Btn, TweenInfo.new(0.1), { BackgroundTransparency = 0.15 }):Play()
		task.delay(0.15, function()
			TweenService:Create(Btn, TweenInfo.new(0.15), { BackgroundTransparency = 0.55 }):Play()
		end)
		if callback then callback() end
	end)

	return Btn
end

function ProjectGalaxy:CreateToggle(tab, text, default, callback)
	local state = default == true

	local Frame = Instance.new("Frame")
	Frame.Size = UDim2.new(1, 0, 0, 40)
	Frame.BackgroundColor3 = Color3.fromRGB(28, 28, 42)
	Frame.BackgroundTransparency = 0.3
	Frame.BorderSizePixel = 0
	Frame.Parent = tab.Content

	Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)

	local FStroke = Instance.new("UIStroke", Frame)
	FStroke.Color = INDIGO
	FStroke.Thickness = 1
	FStroke.Transparency = 0.5

	local Label = Instance.new("TextLabel")
	Label.Text = text
	Label.Size = UDim2.new(1, -68, 1, 0)
	Label.Position = UDim2.new(0, 12, 0, 0)
	Label.BackgroundTransparency = 1
	Label.TextColor3 = TEXT
	Label.Font = Enum.Font.GothamSemibold
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Frame

	local Track = Instance.new("TextButton")
	Track.Size = UDim2.new(0, 46, 0, 24)
	Track.Position = UDim2.new(1, -54, 0.5, -12)
	Track.BackgroundColor3 = state and INDIGO or OFF
	Track.Text = ""
	Track.BorderSizePixel = 0
	Track.Parent = Frame

	Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

	local Knob = Instance.new("Frame")
	Knob.Size = UDim2.new(0, 18, 0, 18)
	Knob.Position = state and UDim2.new(0, 24, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
	Knob.BackgroundColor3 = TEXT
	Knob.BorderSizePixel = 0
	Knob.Parent = Track

	Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)

	Track.MouseButton1Click:Connect(function()
		state = not state
		TweenService:Create(Track, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
			BackgroundColor3 = state and INDIGO or OFF,
		}):Play()
		TweenService:Create(Knob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
			Position = state and UDim2.new(0, 24, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
		}):Play()
		if callback then callback(state) end
	end)

	return Frame
end

function ProjectGalaxy:CreateDropdown(tab, text, options, default, callback)
	local selected = default or (options and options[1]) or "Select..."
	local isOpen = false

	local Wrapper = Instance.new("Frame")
	Wrapper.Size = UDim2.new(1, 0, 0, 64)
	Wrapper.BackgroundTransparency = 1
	Wrapper.Parent = tab.Content

	local Label = Instance.new("TextLabel")
	Label.Text = text
	Label.Size = UDim2.new(1, 0, 0, 20)
	Label.BackgroundTransparency = 1
	Label.TextColor3 = TEXT
	Label.Font = Enum.Font.GothamSemibold
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Wrapper

	local DropBtn = Instance.new("TextButton")
	DropBtn.Size = UDim2.new(1, 0, 0, 36)
	DropBtn.Position = UDim2.new(0, 0, 0, 24)
	DropBtn.BackgroundColor3 = INDIGO_DARK
	DropBtn.BackgroundTransparency = 0.2
	DropBtn.Text = "  " .. selected .. "  ▾"
	DropBtn.TextColor3 = TEXT
	DropBtn.Font = Enum.Font.Gotham
	DropBtn.TextSize = 14
	DropBtn.TextXAlignment = Enum.TextXAlignment.Left
	DropBtn.BorderSizePixel = 0
	DropBtn.Parent = Wrapper

	Instance.new("UICorner", DropBtn).CornerRadius = UDim.new(0, 8)

	local DStroke = Instance.new("UIStroke", DropBtn)
	DStroke.Color = INDIGO
	DStroke.Thickness = 1.5

	local List = Instance.new("Frame")
	List.BackgroundColor3 = Color3.fromRGB(22, 22, 36)
	List.BackgroundTransparency = 0.05
	List.Visible = false
	List.ZIndex = 20
	List.BorderSizePixel = 0
	List.Parent = self.ScreenGui

	Instance.new("UICorner", List).CornerRadius = UDim.new(0, 8)

	local LStroke = Instance.new("UIStroke", List)
	LStroke.Color = INDIGO
	LStroke.Thickness = 1.5

	local LLayout = Instance.new("UIListLayout")
	LLayout.SortOrder = Enum.SortOrder.LayoutOrder
	LLayout.Parent = List

	local ITEM_H = 32

	for _, opt in ipairs(options or {}) do
		local OptBtn = Instance.new("TextButton")
		OptBtn.Size = UDim2.new(1, 0, 0, ITEM_H)
		OptBtn.BackgroundColor3 = INDIGO
		OptBtn.BackgroundTransparency = 1
		OptBtn.Text = "  " .. opt
		OptBtn.TextColor3 = TEXT
		OptBtn.Font = Enum.Font.Gotham
		OptBtn.TextSize = 14
		OptBtn.TextXAlignment = Enum.TextXAlignment.Left
		OptBtn.ZIndex = 21
		OptBtn.BorderSizePixel = 0
		OptBtn.Parent = List

		OptBtn.MouseEnter:Connect(function()
			TweenService:Create(OptBtn, TweenInfo.new(0.1), { BackgroundTransparency = 0.7 }):Play()
		end)
		OptBtn.MouseLeave:Connect(function()
			TweenService:Create(OptBtn, TweenInfo.new(0.1), { BackgroundTransparency = 1 }):Play()
		end)
		OptBtn.MouseButton1Click:Connect(function()
			selected = opt
			DropBtn.Text = "  " .. opt .. "  ▾"
			List.Visible = false
			isOpen = false
			if callback then callback(opt) end
		end)
	end

	local listH = math.min(#(options or {}), 6) * ITEM_H

	DropBtn.MouseButton1Click:Connect(function()
		isOpen = not isOpen
		if isOpen then
			local pos = DropBtn.AbsolutePosition
			local size = DropBtn.AbsoluteSize
			List.Size = UDim2.new(0, size.X, 0, listH)
			List.Position = UDim2.new(0, pos.X, 0, pos.Y + size.Y + 4)
		end
		List.Visible = isOpen
	end)

	return Wrapper
end

function ProjectGalaxy:CreateText(tab, text, isDescription)
	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(1, 0, 0, isDescription and 52 or 28)
	Label.BackgroundTransparency = 1
	Label.Text = text
	Label.TextColor3 = isDescription and SUBTEXT or TEXT
	Label.Font = isDescription and Enum.Font.Gotham or Enum.Font.GothamSemibold
	Label.TextSize = isDescription and 13 or 14
	Label.TextWrapped = true
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = tab.Content
	return Label
end

function ProjectGalaxy:AddTooltip(element, tooltipText)
	local Tip = Instance.new("TextLabel")
	Tip.Size = UDim2.new(0, 190, 0, 34)
	Tip.BackgroundColor3 = Color3.fromRGB(22, 22, 36)
	Tip.BackgroundTransparency = 0.05
	Tip.Text = "  " .. tooltipText
	Tip.TextColor3 = TEXT
	Tip.Font = Enum.Font.Gotham
	Tip.TextSize = 13
	Tip.TextXAlignment = Enum.TextXAlignment.Left
	Tip.Visible = false
	Tip.ZIndex = 30
	Tip.Parent = self.ScreenGui

	Instance.new("UICorner", Tip).CornerRadius = UDim.new(0, 6)

	local TStroke = Instance.new("UIStroke", Tip)
	TStroke.Color = INDIGO
	TStroke.Thickness = 1

	element.MouseEnter:Connect(function()
		local pos = element.AbsolutePosition
		local size = element.AbsoluteSize
		Tip.Position = UDim2.new(0, pos.X + size.X + 8, 0, pos.Y + (size.Y * 0.5) - 17)
		Tip.Visible = true
	end)

	element.MouseLeave:Connect(function()
		Tip.Visible = false
	end)
end

return ProjectGalaxy
