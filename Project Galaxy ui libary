-- Project Galaxy UI Library v2.0 (Optimized & Bug-Fixed)
-- Enhanced for mobile & desktop | Beautiful Smooth Animations

local ProjectGalaxy = {}
ProjectGalaxy.__index = ProjectGalaxy

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

-- ===== COLOR PALETTE =====
local PURPLE = Color3.fromRGB(140, 50, 255)
local PURPLE_DARK = Color3.fromRGB(90, 30, 180)
local BG = Color3.fromRGB(18, 18, 28)
local TEXT = Color3.fromRGB(255, 255, 255)
local SUBTEXT = Color3.fromRGB(170, 170, 190)
local OFF = Color3.fromRGB(45, 45, 60)
local DROPDOWN_BG = Color3.fromRGB(24, 24, 38)
local TOOLTIP_BG = Color3.fromRGB(30, 30, 45)

-- ===== ADAPTIVE SIZING =====
local IsTouch = UserInputService.TouchEnabled and not UserInputService.MouseEnabled
local WINDOW_WIDTH = IsTouch and 360 or 480  -- Made significantly wider
local WINDOW_HEIGHT = IsTouch and 240 or 300 -- Shorter height to remove the "too tall" look

-- ===== HELPER: DRAG FUNCTIONALITY =====
local function MakeDraggable(dragInst, moveInst)
	local dragging, dragStart, startPos
	dragInst.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = moveInst.Position
			input:Capture()
		end
	end)
	dragInst.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			moveInst.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)
end

