function ProjectGalaxy:CreateTab(name)
	local Tab = {}
	
	local TabBtn = Instance.new("TextButton")
	TabBtn.Size = UDim2.new(1, -4, 0, 34)
	TabBtn.BackgroundColor3 = DEEP_PURPLE
	TabBtn.BackgroundTransparency = 0.8
	TabBtn.Text = name
	TabBtn.TextColor3 = TEXT_SUB
	TabBtn.Font = Enum.Font.GothamSemibold
	TabBtn.TextSize = 13
	TabBtn.BorderSizePixel = 0
	TabBtn.Parent = self.TabScroll

	Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

	local TabGroup = Instance.new("CanvasGroup")
	TabGroup.Size = UDim2.new(1, 0, 1, 0)
	TabGroup.BackgroundTransparency = 1
	TabGroup.GroupTransparency = 1
	TabGroup.Visible = false
	TabGroup.Parent = self.ContentContainer

	local TabContent = Instance.new("ScrollingFrame")
	TabContent.Size = UDim2.new(1, 0, 1, 0)
	TabContent.BackgroundTransparency = 1
	TabContent.ScrollBarThickness = 2
	TabContent.ScrollBarImageColor3 = NEON_PURPLE
	TabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
	TabContent.CanvasSize = UDim2.new(0, 0, 0, 0)
	TabContent.Parent = TabGroup

	local ContentLayout = Instance.new("UIListLayout")
	ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
	ContentLayout.Padding = UDim.new(0, 8)
	ContentLayout.Parent = TabContent

	local ContentPad = Instance.new("UIPadding")
	ContentPad.PaddingLeft = UDim.new(0, 8)
	ContentPad.PaddingRight = UDim.new(0, 10)
	ContentPad.PaddingTop = UDim.new(0, 8)
	ContentPad.PaddingBottom = UDim.new(0, 8)
	ContentPad.Parent = TabContent

	Tab.Button = TabBtn
	Tab.Group = TabGroup
	Tab.Content = TabContent

	TabBtn.MouseEnter:Connect(function()
		if self.CurrentTab ~= Tab then
			CreateTween(TabBtn, {BackgroundTransparency = 0.6, TextColor3 = TEXT_MAIN}, 0.15)
		end
	end)

	TabBtn.MouseLeave:Connect(function()
		if self.CurrentTab ~= Tab then
			CreateTween(TabBtn, {BackgroundTransparency = 0.8, TextColor3 = TEXT_SUB}, 0.15)
		end
	end)

	TabBtn.MouseButton1Click:Connect(function()
		if self.CurrentTab and self.CurrentTab ~= Tab then
			local prevTab = self.CurrentTab
			CreateTween(prevTab.Button, {BackgroundTransparency = 0.8, TextColor3 = TEXT_SUB}, 0.2)
			CreateTween(prevTab.Group, {GroupTransparency = 1, Position = UDim2.new(0, -30, 0, 0)}, 0.2)
			task.delay(0.2, function() prevTab.Group.Visible = false end)
		end
		if self.CurrentTab ~= Tab then
			self.CurrentTab = Tab
			TabGroup.Position = UDim2.new(0, 30, 0, 0)
			TabGroup.Visible = true
			CreateTween(TabBtn, {BackgroundTransparency = 0.2, TextColor3 = NEON_PURPLE}, 0.2)
			CreateTween(TabGroup, {GroupTransparency = 0, Position = UDim2.new(0, 0, 0, 0)}, 0.3)
		end
	end)

	if not self.CurrentTab then
		self.CurrentTab = Tab
		TabBtn.BackgroundTransparency = 0.2
		TabBtn.TextColor3 = NEON_PURPLE
		TabGroup.Visible = true
		TabGroup.GroupTransparency = 0
		TabGroup.Position = UDim2.new(0, 0, 0, 0)
	end

	table.insert(self.Tabs, Tab)
	return Tab
end

