	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Frame

	local BindBtn = Instance.new("TextButton")
	BindBtn.Size = UDim2.new(0, 80, 0, 24)
	BindBtn.Position = UDim2.new(1, -92, 0.5, -12)
	BindBtn.BackgroundColor3 = BG_LIGHT
	local keyName = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name
	BindBtn.Text = keyName
	BindBtn.TextColor3 = NEON_PURPLE
	BindBtn.Font = Enum.Font.GothamBold
	BindBtn.TextSize = 12
	BindBtn.BorderSizePixel = 0
	BindBtn.Parent = Frame

	Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 4)
	local BindStroke = Instance.new("UIStroke", BindBtn)
	BindStroke.Color = OUTLINE

	BindBtn.MouseButton1Click:Connect(function()
		isBinding = true
		BindBtn.Text = "..."
		CreateTween(BindStroke, {Color = NEON_PURPLE}, 0.2)
	end)

	UserInputService.InputBegan:Connect(function(input, processed)
		if isBinding then
			if input.UserInputType == Enum.UserInputType.Keyboard then
				local key = input.KeyCode
				if key == Enum.KeyCode.Escape then
					currentKey = Enum.KeyCode.Unknown
					BindBtn.Text = "None"
				else
					currentKey = key
					BindBtn.Text = key.Name
				end
				isBinding = false
				CreateTween(BindStroke, {Color = OUTLINE}, 0.2)
				if callback then pcall(callback, currentKey) end
			end
		elseif not processed then
			if input.KeyCode == currentKey and currentKey ~= Enum.KeyCode.Unknown then
				if callback then pcall(callback, currentKey) end
			end
		end
	end)

	return Frame
end

