-- ===== CREATE SLIDER =====
function ProjectGalaxy:CreateSlider(tab, text, min, max, default, callback)
	local value = default or min

	local Frame = Instance.new("Frame")
	Frame.Size = UDim2.new(1, 0, 0, 48)
	Frame.BackgroundTransparency = 1
	Frame.Parent = tab.Content

	local TopLine = Instance.new("Frame")
	TopLine.Size = UDim2.new(1, 0, 0, 18)
	TopLine.BackgroundTransparency = 1
	TopLine.Parent = Frame

	local Label = Instance.new("TextLabel")
	Label.Text = text
	Label.Size = UDim2.new(1, -45, 1, 0)
	Label.Position = UDim2.new(0, 0, 0, 0)
	Label.BackgroundTransparency = 1
	Label.TextColor3 = TEXT
	Label.Font = Enum.Font.GothamSemibold
	Label.TextSize = 12
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = TopLine

	local ValLabel = Instance.new("TextLabel")
	ValLabel.Text = tostring(value)
	ValLabel.Size = UDim2.new(0, 40, 1, 0)
	ValLabel.Position = UDim2.new(1, -40, 0, 0)
	ValLabel.BackgroundTransparency = 1
	ValLabel.TextColor3 = SUBTEXT
	ValLabel.Font = Enum.Font.Gotham
	ValLabel.TextSize = 11
	ValLabel.TextXAlignment = Enum.TextXAlignment.Right
	ValLabel.Parent = TopLine

	local SliderBar = Instance.new("Frame")
	SliderBar.Size = UDim2.new(1, -16, 0, 6)
	SliderBar.Position = UDim2.new(0, 8, 0, 26)
	SliderBar.BackgroundColor3 = OFF
	SliderBar.BorderSizePixel = 0
	SliderBar.Parent = Frame

	local BarCorner = Instance.new("UICorner", SliderBar)
	BarCorner.CornerRadius = UDim.new(1, 0)

	local Fill = Instance.new("Frame")
	Fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
	Fill.BackgroundColor3 = PURPLE
	Fill.BorderSizePixel = 0
	Fill.Parent = SliderBar

	local FillCorner = Instance.new("UICorner", Fill)
	FillCorner.CornerRadius = UDim.new(1, 0)

	local Knob = Instance.new("TextButton")
	Knob.Size = UDim2.new(0, 14, 0, 14)
	Knob.Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7)
	Knob.BackgroundColor3 = TEXT
	Knob.Text = ""
	Knob.BorderSizePixel = 0
	Knob.Parent = SliderBar

	local KnobCorner = Instance.new("UICorner", Knob)
	KnobCorner.CornerRadius = UDim.new(1, 0)

	local function updateSlider(input)
		local barSize = SliderBar.AbsoluteSize.X
		local relativePos = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X) / barSize, 0, 1)
		value = math.floor(min + (max - min) * relativePos + 0.5)
		Fill.Size = UDim2.new(relativePos, 0, 1, 0)
		Knob.Position = UDim2.new(relativePos, -7, 0.5, -7)
		ValLabel.Text = tostring(value)
		if callback then
			pcall(callback, value)
		end
	end

	SliderBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			updateSlider(input)
			input:Capture()
		end
	end)

	SliderBar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			if input.UserInputState == Enum.UserInputState.Change then
				updateSlider(input)
			end
		end
	end)

	return Frame
end

-- ===== CREATE TEXTBOX =====
function ProjectGalaxy:CreateTextbox(tab, text, placeholder, callback)
	local Wrapper = Instance.new("Frame")
	Wrapper.Size = UDim2.new(1, 0, 0, 50)
	Wrapper.BackgroundTransparency = 1
	Wrapper.Parent = tab.Content

	local Label = Instance.new("TextLabel")
	Label.Text = text
	Label.Size = UDim2.new(1, 0, 0, 18)
	Label.BackgroundTransparency = 1
	Label.TextColor3 = TEXT
	Label.Font = Enum.Font.GothamSemibold
	Label.TextSize = 12
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Wrapper

	local Textbox = Instance.new("TextBox")
	Textbox.Size = UDim2.new(1, 0, 0, 28)
	Textbox.Position = UDim2.new(0, 0, 0, 20)
	Textbox.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
	Textbox.BackgroundTransparency = 0.3
	Textbox.TextColor3 = TEXT
	Textbox.PlaceholderColor3 = SUBTEXT
	Textbox.PlaceholderText = placeholder or "Enter text..."
	Textbox.Font = Enum.Font.Gotham
	Textbox.TextSize = 12
	Textbox.BorderSizePixel = 0
	Textbox.Parent = Wrapper

	Instance.new("UICorner", Textbox).CornerRadius = UDim.new(0, 6)

	local TStroke = Instance.new("UIStroke", Textbox)
	TStroke.Color = PURPLE
	TStroke.Thickness = 1
	TStroke.Transparency = 0.5

	Textbox.FocusLost:Connect(function(enterPressed)
		if enterPressed and callback then
			pcall(callback, Textbox.Text)
		end
	end)

	return Wrapper
end

return ProjectGalaxy
