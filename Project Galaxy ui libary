	Textbox.Size = UDim2.new(1, 0, 0, 24)
	Textbox.Position = UDim2.new(0, 0, 0, 18)
	Textbox.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
	Textbox.BackgroundTransparency = 0.4
	Textbox.TextColor3 = TEXT
	Textbox.PlaceholderColor3 = OFF
	Textbox.PlaceholderText = placeholder or "Enter text..."
	Textbox.Font = Enum.Font.Gotham
	Textbox.TextSize = 11
	Textbox.BorderSizePixel = 0
	Textbox.Parent = Wrapper

	Instance.new("UICorner", Textbox).CornerRadius = UDim.new(0, 5)

	Textbox.FocusLost:Connect(function(enterPressed)
		if callback then pcall(callback, Textbox.Text, enterPressed) end
	end)

	return Wrapper
end

return ProjectGalaxy
