	Knob.Position = UDim2.new(math.clamp((value - min) / (max - min), 0, 1), -7, 0.5, -7)
	Knob.BackgroundColor3 = TEXT_MAIN
	Knob.BorderSizePixel = 0
	Knob.Parent = SliderBar

	Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)

	local function updateValue(newVal)
		value = math.clamp(newVal, min, max)
		local relative = (value - min) / (max - min)
		CreateTween(Fill, {Size = UDim2.new(relative, 0, 1, 0)}, 0.1)
		CreateTween(Knob, {Position = UDim2.new(relative, -7, 0.5, -7)}, 0.1)
		ValBox.Text = tostring(value)
		if callback then pcall(callback, value) end
	end

	local function updateSliderFromInput(input)
		local barSize = SliderBar.AbsoluteSize.X
		local relativePos = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X) / barSize, 0, 1)
		local calculatedValue = math.floor(min + (max - min) * relativePos + 0.5)
		updateValue(calculatedValue)
	end

	local sliding = false
	SliderBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliding = true
			updateSliderFromInput(input)
			input:Capture()
		end
	end)

	SliderBar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliding = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateSliderFromInput(input)
		end
	end)

	ValBox.FocusLost:Connect(function()
		local num = tonumber(ValBox.Text)
		if num then
			updateValue(num)
		else
			ValBox.Text = tostring(value)
		end
	end)

	return Frame
end

