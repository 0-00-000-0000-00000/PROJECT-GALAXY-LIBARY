	MinBtn.TextColor3 = TEXT
	MinBtn.Font = Enum.Font.GothamBold
	MinBtn.TextSize = 18
	MinBtn.ZIndex = 10
	MinBtn.Parent = TitleBar

	MinBtn.MouseButton1Click:Connect(function()
		Window:Minimize()
	end)

	-- Sidebar
	local Sidebar = Instance.new("Frame")
	Sidebar.Size = UDim2.new(0, 115, 1, -44)
	Sidebar.Position = UDim2.new(0, 4, 0, 44)
	Sidebar.BackgroundTransparency = 1
	Sidebar.Parent = Main

	local TabScroll = Instance.new("ScrollingFrame")
	TabScroll.Size = UDim2.new(1, 0, 1, 0)
	TabScroll.BackgroundTransparency = 1
	TabScroll.ScrollBarThickness = 2
	TabScroll.ScrollBarImageColor3 = PURPLE
	TabScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	TabScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	TabScroll.Parent = Sidebar

	local TabLayout = Instance.new("UIListLayout")
	TabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	TabLayout.Padding = UDim.new(0, 4)
	TabLayout.Parent = TabScroll

	local TabPad = Instance.new("UIPadding")
	TabPad.PaddingTop = UDim.new(0, 6)
	TabPad.PaddingLeft = UDim.new(0, 3)
	TabPad.PaddingRight = UDim.new(0, 3)
	TabPad.Parent = TabScroll

	-- Content area
	local ContentArea = Instance.new("Frame")
	ContentArea.Size = UDim2.new(1, -125, 1, -48)
	ContentArea.Position = UDim2.new(0, 122, 0, 44)
	ContentArea.BackgroundTransparency = 1
	ContentArea.ClipsDescendants = true
	ContentArea.Parent = Main

	-- Window dragging
	local dragging, dragStart, startPos = false, nil, nil

	TitleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = Main.Position
			input:Capture()
		end
	end)

	TitleBar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			Main.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)

	-- Minimize/Restore functions
	function Window:Minimize()
		if not Window._bubble then
			Window._bubble = CreateBubble(ScreenGui)
			Window._bubble.MouseButton1Click:Connect(function()
				task.wait(0.1)
				Window:Restore()
			end)
		end
		Window._savedPosition = Main.Position
		Main.Visible = false
		Window._bubble.Visible = true
	end

	function Window:Restore()
		if Window._savedPosition then
			Main.Position = Window._savedPosition
		end
		Main.Visible = true
		if Window._bubble then
			Window._bubble.Visible = false
		end
	end

	-- Store references
	Window.ScreenGui = ScreenGui
	Window.Main = Main
	Window.TabScroll = TabScroll
	Window.ContentArea = ContentArea
	Window.Tabs = {}
	Window.CurrentTab = nil

	return Window
end

-- ===== CREATE TAB =====
function ProjectGalaxy:CreateTab(name)
	local Tab = {}

	local TabBtn = Instance.new("TextButton")
	TabBtn.Size = UDim2.new(1, 0, 0, 32)
	TabBtn.BackgroundColor3 = PURPLE
	TabBtn.BackgroundTransparency = 0.8
	TabBtn.Text = name
	TabBtn.TextColor3 = TEXT
	TabBtn.Font = Enum.Font.GothamSemibold
	TabBtn.TextSize = 12
	TabBtn.BorderSizePixel = 0
	TabBtn.Parent = self.TabScroll

	Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

	local TBStroke = Instance.new("UIStroke", TabBtn)
	TBStroke.Color = PURPLE
	TBStroke.Thickness = 1.2

	local TabContent = Instance.new("ScrollingFrame")
	TabContent.Size = UDim2.new(1, 0, 1, 0)
	TabContent.BackgroundTransparency = 1
	TabContent.ScrollBarThickness = 3
	TabContent.ScrollBarImageColor3 = PURPLE
	TabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
	TabContent.CanvasSize = UDim2.new(0, 0, 0, 0)
	TabContent.Visible = false
	TabContent.Parent = self.ContentArea

	local ContentLayout = Instance.new("UIListLayout")
	ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
	ContentLayout.Padding = UDim.new(0, 8)
	ContentLayout.Parent = TabContent

	local ContentPad = Instance.new("UIPadding")
	ContentPad.PaddingLeft = UDim.new(0, 6)
	ContentPad.PaddingRight = UDim.new(0, 6)
	ContentPad.PaddingTop = UDim.new(0, 6)
	ContentPad.PaddingBottom = UDim.new(0, 6)
	ContentPad.Parent = TabContent

	Tab.Button = TabBtn
	Tab.Content = TabContent

	TabBtn.MouseButton1Click:Connect(function()
		if self.CurrentTab and self.CurrentTab ~= Tab then
			self.CurrentTab.Content.Visible = false
			TweenService:Create(self.CurrentTab.Button, TweenInfo.new(0.15), { BackgroundTransparency = 0.8 }):Play()
		end
		if self.CurrentTab ~= Tab then
			TabContent.Visible = true
			TweenService:Create(TabBtn, TweenInfo.new(0.15), { BackgroundTransparency = 0.3 }):Play()
			self.CurrentTab = Tab
		end
	end)

	if not self.CurrentTab then
		TabContent.Visible = true
		TabBtn.BackgroundTransparency = 0.3
		self.CurrentTab = Tab
	end

	table.insert(self.Tabs, Tab)
	return Tab
end

