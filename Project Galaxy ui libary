local WINDOW_HEIGHT = IsTouch and 420 or 440

-- ===== HELPER: MINIMIZE BUBBLE =====
local function CreateBubble(screenGui)
	local bubble = Instance.new("Frame")
	bubble.Name = "PGBubble"
	bubble.Size = UDim2.new(0, 50, 0, 50)
	bubble.Position = UDim2.new(0.5, -25, 0.5, -25)
	bubble.BackgroundColor3 = PURPLE
	bubble.BorderSizePixel = 0
	bubble.BackgroundTransparency = 0.05
	bubble.ZIndex = 100
	bubble.Parent = screenGui

	local corner = Instance.new("UICorner", bubble)
	corner.CornerRadius = UDim.new(1, 0)

	local stroke = Instance.new("UIStroke", bubble)
	stroke.Color = PURPLE_DARK
	stroke.Thickness = 2

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = "PG"
	label.TextColor3 = TEXT
	label.Font = Enum.Font.GothamBold
	label.TextSize = 20
	label.ZIndex = 101
	label.Parent = bubble

	local textStroke = Instance.new("UIStroke", label)
	textStroke.Color = Color3.new(0, 0, 0)
	textStroke.Thickness = 2

	-- Dragging
	local dragging, dragStart, startPos = false, nil, nil

	bubble.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = bubble.Position
			input:Capture()
		end
	end)

	bubble.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			bubble.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)

	return bubble
end

